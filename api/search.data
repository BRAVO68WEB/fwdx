:4239,"_5":2797,"_1962":35,"_206":4240},[],"Planned evolution toward a server-owned control plane and modern auth.",{"_4160":37,"_2683":35,"_5":2802,"_2851":4242,"_1962":4243,"_206":4234},[],"/docs/architecture/rewrite-direction#rewrite-direction",{"_4160":38,"_2683":35,"_2851":4245,"_5":2797,"_1962":4243,"_206":4246},[],"The rewrite target is a stronger tunnel platform with:",{"_4160":39,"_2683":35,"_2851":4248,"_5":2797,"_1962":4243,"_206":4249},[],"server-owned tunnel records",{"_4160":40,"_2683":35,"_2851":4251,"_5":2797,"_1962":4243,"_206":4252},[],"OIDC-based human authentication",{"_4160":41,"_2683":35,"_2851":4254,"_5":2797,"_1962":4243,"_206":4255},[],"separate agent credentials for machine tunnel registration",{"_4160":42,"_2683":35,"_2851":4257,"_5":2797,"_1962":4243,"_206":4258},[],"better observability and request logs",{"_4160":43,"_2683":35,"_2851":4260,"_5":2797,"_1962":4243,"_206":4261},[],"access controls at ingress",{"_4160":44,"_2683":35,"_2851":4263,"_5":2797,"_1962":4243,"_206":4264},[],"WebSocket support",{"_4160":45,"_2683":35,"_2851":4266,"_5":2797,"_1962":4243,"_206":4267},[],"The current codebase now includes the first persistence foundation:",{"_4160":46,"_2683":35,"_2851":4269,"_5":2797,"_1962":4243,"_206":4270},[],"SQLite-backed tunnel records",{"_4160":47,"_2683":35,"_2851":4272,"_5":2797,"_1962":4243,"_206":4273},[],"persisted request logs",{"_4160":48,"_2683":35,"_2851":4275,"_5":2797,"_1962":4243,"_206":4276},[],"stronger client runtime-state cleanup",{"_4160":49,"_2683":49,"_5":2792,"_206":4229,"_2805":4278,"_2851":4279,"_1962":49},[4163,4164],[],{"_4160":50,"_2683":49,"_2851":4281,"_5":2797,"_1962":49,"_206":4282},[],"How public requests reach the client-side local app.",{"_4160":51,"_2683":49,"_5":2802,"_2851":4284,"_1962":4285,"_206":4229},[],"/docs/architecture/traffic-flow#traffic-flow",{"_4160":52,"_2683":49,"_2851":4287,"_5":2797,"_1962":4285,"_206":4288},[],"Current flow:",{"_4160":53,"_2683":49,"_2851":4290,"_5":2797,"_1962":4285,"_206":4291},[],"Client opens a gRPC stream to the server.",{"_4160":54,"_2683":49,"_2851":4293,"_5":2797,"_1962":4285,"_206":4294},[],"Client registers a hostname.",{"_4160":55,"_2683":49,"_2851":4296,"_5":2797,"_1962":4285,"_206":4297},[],"Browser sends a request to `https://<hostname>`.",{"_4160":56,"_2683":49,"_2851":4299,"_5":2797,"_1962":4285,"_206":4300},[],"Server looks up the active tunnel.",{"_4160":57,"_2683":49,"_2851":4302,"_5":2797,"_1962":4285,"_206":4303},[],"Server sends a proxied request over the stream.",{"_4160":58,"_2683":49,"_2851":4305,"_5":2797,"_1962":4285,"_206":4306},[],"Client forwards that request to the local app.",{"_4160":59,"_2683":49,"_2851":4308,"_5":2797,"_1962":4285,"_206":4309},[],"Client returns the response over the stream.",{"_4160":60,"_2683":49,"_2851":4311,"_5":2797,"_1962":4285,"_206":4312},[],"Server returns that response to the browser.",{"_4160":61,"_2683":49,"_2851":4314,"_5":2797,"_1962":4285,"_206":4315},[],"This model works behind NAT because the client initiates the outbound connection.",{"_4160":62,"_2683":62,"_5":2792,"_206":4317,"_2805":4318,"_2851":4320,"_1962":62},"CLI Device Flow",[4163,4319],"Authentication",[],{"_4160":63,"_2683":62,"_2851":4322,"_5":2797,"_1962":62,"_206":4323},[],"Use OIDC device flow for CLI access.",{"_4160":64,"_2683":62,"_5":2802,"_2851":4325,"_1962":4326,"_206":4317},[],"/docs/authentication/device-flow#cli-device-flow",{"_4160":65,"_2683":62,"_2851":4328,"_5":2797,"_1962":4326,"_206":4329},[],"Log in from the CLI:",{"_4160":66,"_2683":62,"_2851":4331,"_5":2797,"_1962":4326,"_206":4332},[],"The CLI prints:",{"_4160":67,"_2683":62,"_2851":4334,"_5":2797,"_1962":4326,"_206":4335},[],"verification URL",{"_4160":68,"_2683":62,"_2851":4337,"_5":2797,"_1962":4326,"_206":4338},[],"user code",{"_4160":69,"_2683":62,"_2851":4340,"_5":2797,"_1962":4326,"_206":4341},[],"direct verification URL when the provider exposes one",{"_4160":70,"_2683":62,"_2851":4343,"_5":2797,"_1962":4326,"_206":4344},[],"After approval:",{"_4160":71,"_2683":62,"_2851":4346,"_5":2797,"_1962":4326,"_206":4347},[],"Management commands reuse the stored session:",{"_4160":72,"_2683":62,"_2851":4349,"_5":2797,"_1962":4326,"_206":4350},[],"The stored session lives at:",{"_4160":73,"_2683":73,"_5":2792,"_206":4319,"_2805":4352,"_2851":4353,"_1962":73},[4163,4319],[],{"_4160":74,"_2683":73,"_2851":4355,"_5":2797,"_1962":73,"_206":4356},[],"OIDC-only human authentication and current tunnel runtime auth.",{"_4160":75,"_2683":73,"_5":2802,"_2851":4358,"_1962":4359,"_206":4319},[],"/docs/authentication#authentication",{"_4160":76,"_2683":73,"_5":2802,"_2851":4361,"_1962":4362,"_206":4363},[],"/docs/authentication#human-auth","Human auth",{"_4160":77,"_2683":73,"_5":2802,"_2851":4365,"_1962":4366,"_206":4367},[],"/docs/authentication#tunnel-runtime-auth","Tunnel runtime auth",{"_4160":78,"_2683":73,"_5":2802,"_2851":4369,"_1962":4370,"_206":4371},[],"/docs/authentication#pages","Pages",{"_4160":79,"_2683":73,"_2851":4373,"_5":2797,"_1962":4359,"_206":4374},[],"`fwdx` now has a split auth model:",{"_4160":80,"_2683":73,"_2851":4376,"_5":2797,"_1962":4359,"_206":4377},[],"humans authenticate with OIDC",{"_4160":81,"_2683":73,"_2851":4379,"_5":2797,"_1962":4359,"_206":4380},[],"tunnel runtimes authenticate with per-agent credentials",{"_4160":82,"_2683":73,"_2851":4382,"_5":2797,"_1962":4362,"_206":4383},[],"Admin UI: OIDC authorization code flow with PKCE",{"_4160":83,"_2683":73,"_2851":4385,"_5":2797,"_1962":4362,"_206":4386},[],"CLI: OIDC device authorization flow via `fwdx login`",{"_4160":84,"_2683":73,"_2851":4388,"_5":2797,"_1962":4366,"_206":4389},[],"Tunnel clients do not use a shared global runtime token anymore.",{"_4160":85,"_2683":73,"_2851":4391,"_5":2797,"_1962":4366,"_206":4392},[],"the server issues a credential to a named agent",{"_4160":86,"_2683":73,"_2851":4394,"_5":2797,"_1962":4366,"_206":4395},[],"tunnel definitions are stored on the server and assigned to an agent",{"_4160":87,"_2683":73,"_2851":4397,"_5":2797,"_1962":4366,"_206":4398},[],"the local client stores its assigned agent credential in `~/.fwdx/client.json`",{"_4160":88,"_2683":73,"_2851":4400,"_5":2797,"_1962":4370,"_206":4401},[],"OIDC UI Login",{"_4160":89,"_2683":73,"_2851":4403,"_5":2797,"_1962":4370,"_206":4317},[],{"_4160":90,"_2683":90,"_5":2792,"_206":4401,"_2805":4405,"_2851":4406,"_1962":90},[4163,4319],[],{"_4160":91,"_2683":90,"_2851":4408,"_5":2797,"_1962":90,"_206":4409},[],"Configure browser-based OIDC admin login.",{"_4160":92,"_2683":90,"_5":2802,"_2851":4411,"_1962":4412,"_206":4401},[],"/docs/authentication/oidc-ui#oidc-ui-login",{"_4160":93,"_2683":90,"_2851":4414,"_5":2797,"_1962":4412,"_206":4415},[],"Required server settings:",{"_4160":94,"_2683":90,"_2851":4417,"_5":2797,"_1962":4412,"_206":4418},[],"The redirect URL must point back to the `fwdx` server:",{"_4160":95,"_2683":90,"_2851":4420,"_5":2797,"_1962":4412,"_206":4421},[],"Once configured, visit:",{"_4160":96,"_2683":90,"_2851":4423,"_5":2797,"_1962":4412,"_206":4424},[],"The UI redirects to the OIDC provider and returns with a session cookie issued by `fwdx`.",{"_4160":97,"_2683":97,"_5":2792,"_206":4426,"_2805":4427,"_2851":4428,"_1962":97},"CLI Usage",[4163,4426],[],{"_4160":98,"_2683":97,"_2851":4430,"_5":2797,"_1962":97,"_206":4431},[],"Core commands for login, management, tunnel runtime, and diagnostics.",{"_4160":99,"_2683":97,"_5":2802,"_2851":4433,"_1962":4434,"_206":4426},[],"/docs/cli#cli-usage",{"_4160":100,"_2683":97,"_5":2802,"_2851":4436,"_1962":4437,"_206":4438},[],"/docs/cli#server","Server",{"_4160":101,"_2683":97,"_5":2802,"_2851":4440,"_1962":4441,"_206":4363},[],"/docs/cli#human-auth",{"_4160":102,"_2683":97,"_5":2802,"_2851":4443,"_1962":4444,"_206":4445},[],"/docs/cli#management","Management",{"_4160":103,"_2683":97,"_5":2802,"_2851":4447,"_1962":4448,"_206":4449},[],"/docs/cli#tunnel-runtime","Tunnel runtime",{"_4160":104,"_2683":97,"_2851":4451,"_5":2797,"_1962":4434,"_206":4452},[],"The current CLI has four areas:",{"_4160":105,"_2683":97,"_2851":4454,"_5":2797,"_1962":4434,"_206":4455},[],"server startup",{"_4160":106,"_2683":97,"_2851":4457,"_5":2797,"_1962":4434,"_206":4458},[],"OIDC login",{"_4160":107,"_2683":97,"_2851":4460,"_5":2797,"_1962":4434,"_206":4461},[],"admin management",{"_4160":108,"_2683":97,"_2851":4463,"_5":2797,"_1962":4434,"_206":4464},[],"tunnel lifecycle",{"_4160":109,"_2683":97,"_2851":4466,"_5":2797,"_1962":4448,"_206":4467},[],"The CLI provisions an agent credential automatically on first tunnel create/start and stores it locally.",{"_4160":110,"_2683":110,"_5":2792,"_206":4469,"_2805":4470,"_2851":4471,"_1962":110},"Deployment",[4163,4469],[],{"_4160":111,"_2683":110,"_2851":4473,"_5":2797,"_1962":110,"_206":4474},[],"Deploy fwdx with nginx, TLS, and systemd.",{"_4160":112,"_2683":110,"_5":2802,"_2851":4476,"_1962":4477,"_206":4469},[],"/docs/deployment#deployment",{"_4160":113,"_2683":110,"_5":2802,"_2851":4479,"_1962":4480,"_206":4481},[],"/docs/deployment#sections","Sections",{"_4160":114,"_2683":110,"_2851":4483,"_5":2797,"_1962":4477,"_206":4484},[],"The recommended deployment model is:",{"_4160":115,"_2683":110,"_2851":4486,"_5":2797,"_1962":4477,"_206":4487},[],"`fwdx` server running locally on private ports",{"_4160":116,"_2683":110,"_2851":4489,"_5":2797,"_1962":4477,"_206":4490},[],"nginx terminating TLS on `443` and `4443`",{"_4160":117,"_2683":110,"_2851":4492,"_5":2797,"_1962":4477,"_206":4493},[],"wildcard DNS for `*.tunnel.example.com`",{"_4160":118,"_2683":110,"_2851":4495,"_5":2797,"_1962":4480,"_206":2548},[],{"_4160":119,"_2683":110,"_2851":4497,"_5":2797,"_1962":4480,"_206":1139},[],{"_4160":120,"_2683":110,"_2851":4499,"_5":2797,"_1962":4480,"_206":4500},[],"TLS and DNS",{"_4160":121,"_2683":121,"_5":2792,"_206":2548,"_2805":4502,"_2851":4503,"_1962":121},[4163,4469],[],{"_4160":122,"_2683":121,"_2851":4505,"_5":2797,"_1962":121,"_206":4506},[],"Reverse proxy public HTTPS and tunnel gRPC traffic to the fwdx server.",{"_4160":123,"_2683":121,"_5":2802,"_2851":4508,"_1962":4509,"_206":2548},[],"/docs/deployment/nginx#nginx",{"_4160":124,"_2683":121,"_5":2802,"_2851":4511,"_1962":4512,"_206":4513},[],"/docs/deployment/nginx#https-vhost","HTTPS vhost",{"_4160":125,"_2683":121,"_5":2802,"_2851":4515,"_1962":4516,"_206":4517},[],"/docs/deployment/nginx#grpc-stream-block","gRPC stream block",{"_4160":126,"_2683":121,"_2851":4519,"_5":2797,"_1962":4509,"_206":4520},[],"The common layout is:",{"_4160":127,"_2683":121,"_2851":4522,"_5":2797,"_1962":4509,"_206":4523},[],"`443` -> fwdx web port",{"_4160":128,"_2683":121,"_2851":4525,"_5":2797,"_1962":4509,"_206":4526},[],"`4443` -> fwdx gRPC port",{"_4160":129,"_2683":121,"_2851":4528,"_5":2797,"_1962":4509,"_206":4529},[],"If you use ingress IP allowlists, start the server with trusted proxy CIDRs so `fwdx` uses the real visitor IP instead of nginx's loopback address:",{"_4160":130,"_2683":130,"_5":2792,"_206":1139,"_2805":4531,"_2851":4532,"_1962":130},[4163,4469],[],{"_4160":131,"_2683":130,"_2851":4534,"_5":2797,"_1962":130,"_206":4535},[],"Run the fwdx server as a long-lived Linux service.",{"_4160":132,"_2683":130,"_5":2802,"_2851":4537,"_1962":4538,"_206":1139},[],"/docs/deployment/systemd#systemd",{"_4160":133,"_2683":130,"_2851":4540,"_5":2797,"_1962":4538,"_206":4541},[],"Example service:",{"_4160":134,"_2683":130,"_2851":4543,"_5":2797,"_1962":4538,"_206":4544},[],"Logs:",{"_4160":135,"_2683":135,"_5":2792,"_206":4500,"_2805":4546,"_2851":4547,"_1962":135},[4163,4469],[],{"_4160":136,"_2683":135,"_2851":4549,"_5":2797,"_1962":135,"_206":4550},[],"DNS records and certificates required for public tunnel routing.",{"_4160":137,"_2683":135,"_5":2802,"_2851":4552,"_1962":4553,"_206":4500},[],"/docs/deployment/tls-dns#tls-and-dns",{"_4160":138,"_2683":135,"_5":2802,"_2851":4555,"_1962":4556,"_206":4557},[],"/docs/deployment/tls-dns#dns","DNS",{"_4160":139,"_2683":135,"_5":2802,"_2851":4559,"_1962":4560,"_206":4561},[],"/docs/deployment/tls-dns#tls","TLS",{"_4160":140,"_2683":135,"_2851":4563,"_5":2797,"_1962":4556,"_206":4564},[],"You need:",{"_4160":141,"_2683":135,"_2851":4566,"_5":2797,"_1962":4556,"_206":4567},[],"`tunnel.example.com` -> server public IP",{"_4160":142,"_2683":135,"_2851":4569,"_5":2797,"_1962":4556,"_206":4570},[],"`*.tunnel.example.com` -> server public IP",{"_4160":143,"_2683":135,"_2851":4572,"_5":2797,"_1962":4560,"_206":4573},[],"The certificate must cover:",{"_4160":144,"_2683":135,"_2851":4575,"_5":2797,"_1962":4560,"_206":4576},[],"`tunnel.example.com`",{"_4160":145,"_2683":135,"_2851":4578,"_5":2797,"_1962":4560,"_206":4579},[],"`*.tunnel.example.com`",{"_4160":146,"_2683":135,"_2851":4581,"_5":2797,"_1962":4560,"_206":4582},[],"If nginx terminates TLS, fwdx itself can stay on plain local ports.",{"_4160":147,"_2683":147,"_5":2792,"_206":4584,"_2805":4585,"_2851":4586,"_1962":147},"fwdx Docs",[4163],[],{"_4160":148,"_2683":147,"_2851":4588,"_5":2797,"_1962":147,"_206":4589},[],"Self-hosted tunnel platform documentation for installation, CLI usage, deployment, and architecture.",{"_4160":149,"_2683":147,"_5":2802,"_2851":4591,"_1962":4592,"_206":2343},[],"/docs#fwdx",{"_4160":150,"_2683":147,"_5":2802,"_2851":4594,"_1962":4595,"_206":4596},[],"/docs#documentation","Documentation",{"_4160":151,"_2683":147,"_5":2802,"_2851":4598,"_1962":4599,"_206":4600},[],"/docs#current-product-scope","Current Product Scope",{"_4160":152,"_2683":147,"_5":2802,"_2851":4602,"_1962":4603,"_206":4604},[],"/docs#next-rewrite-direction","Next Rewrite Direction",{"_4160":153,"_2683":147,"_2851":4606,"_5":2797,"_1962":4592,"_206":4607},[],"`fwdx` is a self-hosted tunnel platform for exposing local HTTP services through your own domain.",{"_4160":154,"_2683":147,"_2851":4609,"_5":2797,"_1962":4595,"_206":4610},[],"Installation",{"_4160":155,"_2683":147,"_2851":4612,"_5":2797,"_1962":4595,"_206":4426},[],{"_4160":156,"_2683":147,"_2851":4614,"